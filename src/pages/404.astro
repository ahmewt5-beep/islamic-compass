---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Sayfa Bulunamadı | Islamic Compass" canonicalURL="https://islamiccompass.org/404">
  <main class="min-h-[70vh] flex flex-col items-center justify-center px-5 text-center">
    <div class="text-[#D4AF37] text-9xl font-['Playfair_Display'] font-bold mb-6">404</div>
    <h1 class="text-3xl md:text-4xl font-semibold text-[#1C1917] dark:text-white mb-6">Aradığınız Sayfa Bulunamadı</h1>
    <p class="text-[#94A3B8] mb-10 max-w-md">Belki de yanlış bir yola saptınız. Gönül Pusulanızı kullanarak ana sayfaya dönebilirsiniz.</p>
    <a href="/" class="px-8 py-3 bg-[#1C1917] dark:bg-white text-white dark:text-[#1C1917] font-bold rounded-full hover:bg-[#D4AF37] dark:hover:bg-[#D4AF37] hover:text-white transition-all duration-300">
      Ana Sayfaya Dön
    </a>
  </main>
</Layout>