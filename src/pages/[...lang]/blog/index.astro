---
import Layout from '../../../layouts/Layout.astro';
import { veriGetir } from '../../../utils/veriMotoru';
import { useTranslations } from '../../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { lang: undefined } }, { params: { lang: 'en' } }, { params: { lang: 'ar' } },
    { params: { lang: 'id' } }, { params: { lang: 'ur' } }, { params: { lang: 'fr' } }, { params: { lang: 'ru' } },
  ];
}

const lang = Astro.params.lang || 'tr';
const t = useTranslations(lang);
const langPrefix = lang === 'tr' ? '' : `/${lang}`;

const blogData = veriGetir('blog_proje_hazir', lang);
---

<Layout title={`${t('nav.blog')} | ${t('hero.title')}`} lang={lang}>
  <main class="py-16 md:py-24 px-5 transition-colors duration-500">
    <div class="max-w-7xl mx-auto">
      
      <header class="text-center mb-20">
        <span class="text-[#D4AF37] text-sm font-bold tracking-[0.2em] uppercase mb-4 block">{t('hero.badge')}</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-['Playfair_Display'] font-semibold text-[#1C1917] dark:text-white mb-6 transition-colors duration-500">
          {t('nav.blog')}
        </h1>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {blogData.map((yazi) => (
          <a href={`${langPrefix}/blog/${yazi.seo_url}`} class="group block bg-white dark:bg-[#111827]/40 border border-black/5 dark:border-white/5 hover:border-[#D4AF37]/50 rounded-[2rem] p-8 hover:-translate-y-2 transition-all duration-500 shadow-sm hover:shadow-xl flex flex-col h-full">
            
            <div class="flex-grow">
              <span class="inline-block px-3 py-1 bg-[#FDFBF7] dark:bg-[#0B1120] text-[#D4AF37] text-[10px] font-bold tracking-[0.2em] uppercase rounded-full mb-6 border border-[#D4AF37]/20">
                {lang === 'tr' ? 'İslami Makale' : 'Article'}
              </span>
              <h2 class="text-2xl font-['Playfair_Display'] font-bold text-[#1C1917] dark:text-white mb-4 group-hover:text-[#D4AF37] transition-colors line-clamp-2">
                {yazi.baslik}
              </h2>
              <p class="text-[#57534E] dark:text-[#94A3B8] text-sm line-clamp-3 leading-relaxed transition-colors duration-500 font-light">
                {yazi.seo_meta_aciklama || yazi.meta_aciklama}
              </p>
            </div>

            <div class="mt-8 pt-6 border-t border-black/5 dark:border-white/5 flex items-center justify-between text-xs text-[#94A3B8] font-medium uppercase tracking-wider">
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-[#D4AF37]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                {yazi.yazar || t('hero.title')}
              </span>
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-[#D4AF37]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                {yazi.okuma_suresi || (lang === 'tr' ? '5 dk' : '5 min')}
              </span>
            </div>

          </a>
        ))}
      </div>

    </div>
  </main>
</Layout>