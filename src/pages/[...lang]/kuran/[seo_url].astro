---
import Layout from '../../../layouts/Layout.astro';
import { veriGetir } from '../../../utils/veriMotoru';
import { useTranslations } from '../../../i18n/ui';

// 7 Dil ve 114 Sure için Çapraz Sayfa Üretimi (Matrix Routing)
export function getStaticPaths() {
  const diller = [undefined, 'en', 'ar', 'id', 'ur', 'fr', 'ru'];
  const paths = [];

  diller.forEach(dilParam => {
    const gecerliDil = dilParam || 'tr';
    const kuranData = veriGetir('kuran_proje_hazir', gecerliDil);

    kuranData.forEach((sure) => {
      // Önceki ve sonraki sureleri bulmak için güvenlik filtresi
      const ilgiliIcerikler = kuranData
        .filter((s) => s.sure_no !== sure.sure_no)
        .slice(sure.sure_no, sure.sure_no + 3);

      const guvenliIcerikler = ilgiliIcerikler.length > 0 ? ilgiliIcerikler : kuranData.slice(0, 3);

      paths.push({
        params: { lang: dilParam, seo_url: sure.seo_url },
        props: { sure, ilgiliIcerikler: guvenliIcerikler, gecerliDil },
      });
    });
  });

  return paths;
}

const { sure, ilgiliIcerikler, gecerliDil } = Astro.props;
const lang = gecerliDil;
const t = useTranslations(lang);
const langPrefix = lang === 'tr' ? '' : `/${lang}`;

const sureSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": sure.sure_adi,
  "description": sure.seo_meta_aciklama,
  "keywords": Array.isArray(sure.semantik_etiketler) 
                ? sure.semantik_etiketler.join(", ") 
                : (sure.semantik_etiketler || ""),
  "inLanguage": ["ar", lang]
};
---

<Layout title={`${sure.sure_adi} | ${t('section.kuran')}`} schema={sureSchema} description={sure.seo_meta_aciklama} canonicalURL={`https://islamscompass.com${langPrefix}/kuran/${sure.seo_url}`} lang={lang}>
  
  <style is:global>
    html {
      scroll-behavior: smooth;
    }
  </style>

  <main class="py-16 md:py-24 px-5">
    <article class="max-w-4xl mx-auto">
      
      <header class="text-center mb-10 relative">
        <div class="text-[#D4AF37] text-[10px] md:text-xs font-bold tracking-[0.2em] uppercase mb-6">
          {t('section.kuran')} - {sure.sure_no}
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-['Playfair_Display'] font-semibold text-[#1C1917] dark:text-white mb-8 leading-tight transition-colors duration-500">
          {sure.sure_adi}
        </h1>

        <p class="text-[#57534E] dark:text-[#94A3B8] text-lg md:text-xl leading-relaxed font-light max-w-2xl mx-auto transition-colors duration-500 bg-[#FDFBF7] dark:bg-[#0B1120] px-4">
          "{sure.sayfa_giris_yazisi}"
        </p>
      </header>

      <div class="flex flex-wrap items-center justify-center gap-4 mb-16">
        <button id="play-audio-btn" data-surah-no={sure.sure_no} class="group relative px-6 py-2.5 rounded-full bg-[#D4AF37] border border-[#D4AF37] text-white dark:text-[#0B1120] text-xs font-bold tracking-widest uppercase shadow-lg shadow-[#D4AF37]/20 hover:shadow-[#D4AF37]/40 hover:-translate-y-0.5 transition-all duration-300 flex items-center justify-center gap-3 overflow-hidden">
          <span class="absolute inset-0 w-full h-full bg-white/20 group-hover:bg-transparent transition-colors duration-300"></span>
          <svg id="play-icon" class="w-4 h-4 relative z-10" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          <svg id="pause-icon" class="w-4 h-4 relative z-10 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
          <svg id="loading-icon" class="w-4 h-4 relative z-10 hidden animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
          <span id="audio-text" class="relative z-10">Mishary Rashid</span>
        </button>
        <audio id="quran-audio" class="hidden"></audio>

        <a href="#arapca" class="px-6 py-2.5 rounded-full bg-[#F5F2E9] dark:bg-[#111827]/50 border border-[#D4AF37]/30 text-[#D4AF37] text-xs font-bold tracking-widest uppercase hover:bg-[#D4AF37] hover:text-white dark:hover:text-[#0B1120] transition-all duration-300">
          العربية
        </a>
        {lang !== 'ar' && (
          <a href="#okunus" class="px-6 py-2.5 rounded-full bg-[#F5F2E9] dark:bg-[#111827]/50 border border-[#D4AF37]/30 text-[#D4AF37] text-xs font-bold tracking-widest uppercase hover:bg-[#D4AF37] hover:text-white dark:hover:text-[#0B1120] transition-all duration-300">
            A-Z
          </a>
        )}
        {lang !== 'ar' && (
          <a href="#meal" class="px-6 py-2.5 rounded-full bg-[#F5F2E9] dark:bg-[#111827]/50 border border-[#D4AF37]/30 text-[#D4AF37] text-xs font-bold tracking-widest uppercase hover:bg-[#D4AF37] hover:text-white dark:hover:text-[#0B1120] transition-all duration-300">
            {lang.toUpperCase()}
          </a>
        )}
      </div>

      <section id="arapca" class="mb-12 scroll-mt-24">
        <div class="bg-gradient-to-b from-[#F3F0E6] dark:from-[#111827]/60 to-transparent rounded-[2.5rem] p-8 md:p-16 text-center border-t border-black/5 dark:border-white/5 transition-colors duration-500 shadow-lg">
          <p class="text-4xl md:text-5xl lg:text-6xl text-[#1C1917] dark:text-white font-['Amiri'] transition-colors duration-500" dir="rtl" style="line-height: 2.8;">
            {sure.tamami_arapca}
          </p>
        </div>
      </section>

      {lang !== 'ar' && (
        <div class="space-y-12 mb-20">
          
          <section id="okunus" class="scroll-mt-24 p-8 md:p-12 rounded-[2.5rem] bg-[#F5F2E9] dark:bg-[#111827]/30 border border-black/5 dark:border-white/5 transition-colors duration-500">
            <h2 class="text-[#D4AF37] text-xs font-bold tracking-[0.2em] uppercase mb-8 flex items-center justify-center md:justify-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#D4AF37]"></span>
              Transliteration
            </h2>
            <p class="text-[#44403C] dark:text-white/90 text-lg md:text-xl leading-loose font-light text-center md:text-left transition-colors duration-500 whitespace-pre-wrap" dir="ltr">
              {sure.tamami_okunus}
            </p>
          </section>

          <section id="meal" class="scroll-mt-24 p-8 md:p-12 rounded-[2.5rem] bg-[#F5F2E9] dark:bg-[#111827]/30 border border-black/5 dark:border-white/5 transition-colors duration-500">
            <h2 class="text-[#D4AF37] text-xs font-bold tracking-[0.2em] uppercase mb-8 flex items-center justify-center md:justify-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#D4AF37]"></span>
              Translation ({lang.toUpperCase()})
            </h2>
            <p class="text-[#44403C] dark:text-white/90 text-lg md:text-xl leading-loose font-light text-center md:text-left transition-colors duration-500 whitespace-pre-wrap">
              {sure.tamami_meal}
            </p>
          </section>

        </div>
      )}

      {ilgiliIcerikler.length > 0 && (
        <section class="mt-20 pt-16 border-t border-black/10 dark:border-white/10 transition-colors duration-500">
          <div class="grid md:grid-cols-3 gap-6">
            {ilgiliIcerikler.map((ilgili) => (
              <a href={`${langPrefix}/kuran/${ilgili.seo_url}`} class="group block p-6 md:p-8 rounded-[2rem] bg-[#F5F2E9] dark:bg-[#111827]/30 border border-black/5 dark:border-white/5 hover:bg-[#EAE5D9] dark:hover:bg-[#111827]/50 transition-all duration-500 hover:-translate-y-2">
                <span class="text-[#D4AF37] text-[10px] font-bold tracking-[0.2em] uppercase mb-4 block">
                  {ilgili.sure_no}
                </span>
                <h4 class="text-lg md:text-xl font-['Playfair_Display'] font-bold text-[#1C1917] dark:text-white mb-3 group-hover:text-[#D4AF37] dark:group-hover:text-[#D4AF37] transition-colors line-clamp-2">
                  {ilgili.sure_adi}
                </h4>
                <p class="text-[#57534E] dark:text-[#94A3B8] text-sm line-clamp-2 font-light transition-colors duration-500">
                  {ilgili.sayfa_giris_yazisi}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

    </article>
  </main>

  <script>
    // AlQuran.cloud API Entegrasyonu
    document.addEventListener('DOMContentLoaded', () => {
      const playBtn = document.getElementById('play-audio-btn');
      const audioEl = document.getElementById('quran-audio');
      const playIcon = document.getElementById('play-icon');
      const pauseIcon = document.getElementById('pause-icon');
      const loadingIcon = document.getElementById('loading-icon');
      const audioText = document.getElementById('audio-text');
      
      let isPlaying = false;
      let audioLoaded = false;
      let currentAyahIndex = 0;

      if (playBtn && audioEl) {
        playBtn.addEventListener('click', async () => {
          const surahNo = playBtn.getAttribute('data-surah-no');
          
          if (!audioLoaded) {
            playIcon.classList.add('hidden');
            loadingIcon.classList.remove('hidden');

            try {
              const response = await fetch(`https://api.alquran.cloud/v1/surah/${surahNo}/ar.alafasy`);
              const data = await response.json();
              
              if (data.code === 200 && data.status === 'OK') {
                 const ayahs = data.data.ayahs;
                 
                 const playNextAyah = () => {
                   if (currentAyahIndex < ayahs.length) {
                     audioEl.src = ayahs[currentAyahIndex].audio;
                     audioEl.play().catch(e => console.error("Oynatma hatası:", e));
                     currentAyahIndex++;
                   } else {
                     resetPlayer();
                   }
                 };

                 audioEl.addEventListener('ended', playNextAyah);
                 
                 audioEl.src = ayahs[0].audio;
                 audioLoaded = true;
                 currentAyahIndex = 1;

                 loadingIcon.classList.add('hidden');
                 pauseIcon.classList.remove('hidden');
                 audioEl.play().catch(e => console.error("Oynatma hatası:", e));
                 isPlaying = true;

              } else {
                 throw new Error("Ses dosyası bulunamadı.");
              }
            } catch (error) {
              console.error("API Hatası:", error);
              loadingIcon.classList.add('hidden');
              playIcon.classList.remove('hidden');
            }
          } else {
            if (isPlaying) {
              audioEl.pause();
              pauseIcon.classList.add('hidden');
              playIcon.classList.remove('hidden');
            } else {
              audioEl.play().catch(e => console.error("Oynatma hatası:", e));
              playIcon.classList.add('hidden');
              pauseIcon.classList.remove('hidden');
            }
            isPlaying = !isPlaying;
          }
        });

        const resetPlayer = () => {
          isPlaying = false;
          audioLoaded = false;
          pauseIcon.classList.add('hidden');
          loadingIcon.classList.add('hidden');
          playIcon.classList.remove('hidden');
          currentAyahIndex = 0;
        };
      }
    });
  </script>
</Layout>