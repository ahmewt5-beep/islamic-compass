---
import Layout from '../../../layouts/Layout.astro';
import { veriGetir } from '../../../utils/veriMotoru';
import { useTranslations } from '../../../i18n/ui';

const { lang = 'tr', seo_url } = Astro.params;
const t = useTranslations(lang);
const langPrefix = lang === 'tr' ? '' : `/${lang}`;

const mezhepler = veriGetir('mezhepler_proje_hazir', lang) || [];
const imam = mezhepler.find(m => m.seo_url === seo_url);

if (!imam) {
  return Astro.redirect(`${langPrefix}/mezhepler`);
}

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": imam.imam_adi,
  "description": imam.genel_ozellikler
};

// 🌍 SAYFA İÇİ OTOMATİK ÇEVİRİ SÖZLÜĞÜ
const uiTarihce = {
  tr: 'Tarihçe ve Yayılış',
  en: 'History and Spread',
  ar: 'التاريخ والانتشار',
  ru: 'История и распространение',
  fr: 'Histoire et Propagation',
  id: 'Sejarah dan Penyebaran',
  ur: 'تاریخ اور پھیلاؤ'
}[lang] || 'Tarihçe ve Yayılış';

const uiBiyografi = {
  tr: 'Destansı Biyografi',
  en: 'Epic Biography',
  ar: 'سيرة ملحمية',
  ru: 'Эпическая биография',
  fr: 'Biographie Épique',
  id: 'Biografi Epik',
  ur: 'عظیم سوانح حیات'
}[lang] || 'Destansı Biyografi';

const uiGeriDon = {
  tr: 'Mezhepler Ana Sayfasına Dön',
  en: 'Return to Sects Home',
  ar: 'العودة إلى المذاهب',
  ru: 'Вернуться к мазхабам',
  fr: 'Retour aux Madhhabs',
  id: 'Kembali ke Mazhab',
  ur: 'مسالک پر واپس جائیں'
}[lang] || 'Mezhepler Ana Sayfasına Dön';
---

<Layout title={`${imam.imam_adi} | Islamic Compass`} description={imam.genel_ozellikler} schema={schema}>
  
  <main class="py-16 md:py-24 px-5">
    <article class="max-w-4xl mx-auto">
      
      <header class="text-center mb-16 border-b border-black/5 dark:border-white/5 pb-16">
        <div class="text-[#D4AF37] text-[10px] md:text-xs font-bold tracking-[0.2em] uppercase mb-6">
          {imam.mezhep_adi}
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-['Playfair_Display'] font-semibold text-[#1C1917] dark:text-white mb-10 leading-tight">
          {imam.imam_adi}
        </h1>

        <p class="text-[#57534E] dark:text-[#94A3B8] text-lg md:text-xl leading-relaxed font-light max-w-2xl mx-auto italic">
          "{imam.genel_ozellikler}"
        </p>
      </header>

      <section class="mb-16 bg-[#F5F2E9] dark:bg-[#111827] rounded-[2rem] p-8 md:p-12 border border-[#D4AF37]/20 shadow-lg">
        <h2 class="text-xl md:text-2xl font-bold text-[#1C1917] dark:text-white mb-6 flex items-center gap-3">
          <svg class="w-6 h-6 text-[#D4AF37]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          {uiTarihce}
        </h2>
        <p class="text-[#57534E] dark:text-[#94A3B8] leading-loose text-lg font-light">
          {imam.tarihce_ve_yayilis}
        </p>
      </section>

      <section class="prose prose-lg dark:prose-invert prose-headings:font-['Playfair_Display'] prose-headings:text-[#D4AF37] prose-p:text-[#44403C] dark:prose-p:text-white/80 prose-p:leading-loose prose-p:font-light max-w-none">
        
        <h2 class="text-3xl md:text-4xl text-center mb-10">{uiBiyografi}</h2>
        
        <div set:html={imam.detayli_biyografi}></div>

      </section>

      <div class="mt-20 text-center">
        <a href={`${langPrefix}/mezhepler`} class="inline-flex items-center px-8 py-3 rounded-full border border-black/10 dark:border-white/10 text-[#57534E] dark:text-[#94A3B8] text-xs font-bold tracking-widest uppercase hover:bg-[#D4AF37] hover:text-white hover:border-[#D4AF37] transition-all duration-300">
          <svg class="w-4 h-4 mr-2 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          {uiGeriDon}
        </a>
      </div>

    </article>
  </main>
</Layout>