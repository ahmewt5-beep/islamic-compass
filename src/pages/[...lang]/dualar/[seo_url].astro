---
import Layout from '../../../layouts/Layout.astro';
import { veriGetir } from '../../../utils/veriMotoru';
import { useTranslations } from '../../../i18n/ui';

// 7 Dil x Tüm Dualar için Çapraz Sayfa Üretimi
export function getStaticPaths() {
  const diller = [undefined, 'en', 'ar', 'id', 'ur', 'fr', 'ru'];
  const paths = [];

  diller.forEach(dilParam => {
    const gecerliDil = dilParam || 'tr';
    const dualarData = veriGetir('dualar_proje_hazir', gecerliDil);

    dualarData.forEach((dua) => {
      // Aynı kategorideki diğer 3 duayı buluyoruz
      const ilgiliIcerikler = dualarData
        .filter((d) => d.seo_url !== dua.seo_url && d.kategori === dua.kategori)
        .slice(0, 3);

      paths.push({
        params: { lang: dilParam, seo_url: dua.seo_url },
        props: { dua, ilgiliIcerikler, gecerliDil },
      });
    });
  });

  return paths;
}

const { dua, ilgiliIcerikler, gecerliDil } = Astro.props;
const lang = gecerliDil;
const t = useTranslations(lang);
const langPrefix = lang === 'tr' ? '' : `/${lang}`;

// GOOGLE FAQ ŞEMASI - Her dile göre otomatik çevrilir
const duaSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `${dua.baslik} (${lang.toUpperCase()})`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": dua.turkce_anlam
      }
    }
  ]
};
---

<Layout 
  title={`${dua.baslik} | ${t('section.dualar')}`} 
  description={dua.sayfa_giris_yazisi || dua.turkce_anlam} 
  canonicalURL={`https://islamiccompass.org${langPrefix}/dualar/${dua.seo_url}`}
  schema={duaSchema}
  lang={lang}
>
  <main class="py-16 md:py-24 px-5">
    <article class="max-w-3xl mx-auto">
      
      <header class="text-center mb-16">
        <div class="text-[#D4AF37] text-[10px] md:text-xs font-bold tracking-[0.2em] uppercase mb-6">{dua.kategori}</div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-['Playfair_Display'] font-semibold text-[#1C1917] dark:text-white mb-8 leading-tight transition-colors duration-500">
          {dua.baslik}
        </h1>
        {dua.sayfa_giris_yazisi && (
          <p class="text-[#57534E] dark:text-[#94A3B8] text-lg md:text-xl leading-relaxed font-['Playfair_Display'] italic max-w-2xl mx-auto transition-colors duration-500">
            "{dua.sayfa_giris_yazisi}"
          </p>
        )}
      </header>

      <section class="mb-20">
        <div class="bg-gradient-to-b from-[#F3F0E6] dark:from-[#111827]/60 to-transparent rounded-[2.5rem] p-8 md:p-16 text-center border-t border-black/5 dark:border-white/5 transition-colors duration-500 shadow-sm">
          <p class="text-4xl md:text-5xl lg:text-6xl text-[#1C1917] dark:text-white font-['Amiri'] transition-colors duration-500" dir="rtl" style="line-height: 2.8;">
            {dua.arapca_metin || dua.arapca}
          </p>
        </div>
      </section>

      <div class={`grid ${lang === 'ar' ? 'grid-cols-1' : 'md:grid-cols-2'} gap-8 mb-20`}>
        
        {lang !== 'ar' && (
          <div class="p-8 md:p-10 rounded-[2rem] bg-[#F5F2E9] dark:bg-[#111827]/30 border border-black/5 dark:border-white/5 hover:bg-[#EAE5D9] dark:hover:bg-[#111827]/50 transition-colors duration-500">
            <h2 class="text-[#D4AF37] text-xs font-bold tracking-[0.2em] uppercase mb-6 flex items-center justify-center md:justify-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#D4AF37]"></span>
              Transliteration
            </h2>
            <p class="text-[#44403C] dark:text-white/90 text-lg md:text-xl leading-relaxed font-light text-center md:text-left transition-colors duration-500">
              {dua.turkce_okunus || dua.okunusu}
            </p>
          </div>
        )}

        <div class={`p-8 md:p-10 rounded-[2rem] bg-[#F5F2E9] dark:bg-[#111827]/30 border border-black/5 dark:border-white/5 hover:bg-[#EAE5D9] dark:hover:bg-[#111827]/50 transition-colors duration-500 ${lang === 'ar' ? 'max-w-2xl mx-auto w-full' : ''}`}>
          <h2 class="text-[#D4AF37] text-xs font-bold tracking-[0.2em] uppercase mb-6 flex items-center justify-center md:justify-start gap-3">
            <span class="w-2 h-2 rounded-full bg-[#D4AF37]"></span>
            Translation ({lang.toUpperCase()})
          </h2>
          <p class="text-[#44403C] dark:text-white/90 text-lg md:text-xl leading-relaxed font-light text-center md:text-left transition-colors duration-500">
            {dua.turkce_anlam}
          </p>
        </div>
      </div>

      {(dua.fazileti_ve_kaynagi || dua.kaynak) && (
        <footer class="mt-10 pt-10 border-t border-black/5 dark:border-white/10 text-center transition-colors duration-500">
          <h3 class="text-[#D4AF37] font-bold mb-4 text-xs tracking-[0.2em] uppercase">Info & Source</h3>
          <p class="text-[#57534E] dark:text-[#94A3B8] leading-relaxed text-base max-w-2xl mx-auto transition-colors duration-500">
            {dua.fazileti_ve_kaynagi || dua.kaynak}
          </p>
        </footer>
      )}

      {ilgiliIcerikler.length > 0 && (
        <section class="mt-24 pt-16 border-t border-black/10 dark:border-white/10 transition-colors duration-500">
          <div class="text-center mb-10">
            <h3 class="text-2xl md:text-3xl font-['Playfair_Display'] font-semibold text-[#1C1917] dark:text-white transition-colors duration-500">
              {t('section.dualar')}
            </h3>
          </div>
          
          <div class="grid md:grid-cols-3 gap-6">
            {ilgiliIcerikler.map((ilgili) => (
              <a href={`${langPrefix}/dualar/${ilgili.seo_url}`} class="group block p-6 md:p-8 rounded-[2rem] bg-[#F5F2E9] dark:bg-[#111827]/30 border border-black/5 dark:border-white/5 hover:bg-[#EAE5D9] dark:hover:bg-[#111827]/50 transition-all duration-500 hover:-translate-y-2">
                <span class="text-[#D4AF37] text-[10px] font-bold tracking-[0.2em] uppercase mb-4 block">{ilgili.kategori}</span>
                <h4 class="text-lg md:text-xl font-['Playfair_Display'] font-bold text-[#1C1917] dark:text-white mb-3 group-hover:text-[#D4AF37] dark:group-hover:text-[#D4AF37] transition-colors line-clamp-2">
                  {ilgili.baslik}
                </h4>
                <p class="text-[#57534E] dark:text-[#94A3B8] text-sm line-clamp-2 font-light transition-colors duration-500">
                  {ilgili.sayfa_giris_yazisi || ilgili.turkce_anlam}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}
      
    </article>
  </main>
</Layout>