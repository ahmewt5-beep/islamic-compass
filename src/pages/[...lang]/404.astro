---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { lang: undefined } }, // Türkçe
    { params: { lang: 'en' } },
    { params: { lang: 'ar' } },
    { params: { lang: 'id' } },
    { params: { lang: 'ur' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ru' } },
  ];
}

const lang = Astro.params.lang || 'tr';
const t = useTranslations(lang);
const langPrefix = lang === 'tr' ? '' : `/${lang}`;
---
<Layout title={`${t('404.title')} | Islamic Compass`} canonicalURL={`https://islamiccompass.org${langPrefix}/404`} lang={lang}>
  <main class="min-h-[70vh] flex flex-col items-center justify-center px-5 text-center">
    <div class="text-[#D4AF37] text-9xl font-['Playfair_Display'] font-bold mb-6">404</div>
    <h1 class="text-3xl md:text-4xl font-semibold text-[#1C1917] dark:text-white mb-6">{t('404.desc')}</h1>
    <p class="text-[#94A3B8] mb-10 max-w-md">{t('404.detail')}</p>
    <a href={`${langPrefix}/`} class="px-8 py-3 bg-[#1C1917] dark:bg-white text-white dark:text-[#1C1917] font-bold rounded-full hover:bg-[#D4AF37] dark:hover:bg-[#D4AF37] hover:text-white transition-all duration-300">
      {t('404.back')}
    </a>
  </main>
</Layout>
