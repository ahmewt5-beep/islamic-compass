---
import Layout from '../../../layouts/Layout.astro';
import { veriGetir } from '../../../utils/veriMotoru';
import { useTranslations } from '../../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'en' } },
    { params: { lang: 'ar' } },
    { params: { lang: 'id' } },
    { params: { lang: 'ur' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ru' } },
  ];
}

const lang = Astro.params.lang || 'tr';
const t = useTranslations(lang);
const langPrefix = lang === 'tr' ? '' : `/${lang}`;

const hadisData = veriGetir('hadisler_proje_hazir', lang);
---

<Layout title={`${t('section.hadis')} | ${t('hero.title')}`} lang={lang}>
  <main class="py-16 md:py-24 px-5 transition-colors duration-500">
    <div class="max-w-6xl mx-auto">
      
      <header class="text-center mb-16">
        <span class="text-[#D4AF37] text-sm font-bold tracking-[0.2em] uppercase mb-4 block">{t('hero.badge')}</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-['Playfair_Display'] font-semibold text-[#1C1917] dark:text-white mb-6 transition-colors duration-500">
          {t('section.hadis')}
        </h1>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {hadisData.map((kategori) => (
          <a href={`${langPrefix}/hadisler/${kategori.seo_url}`} class="group block bg-white dark:bg-[#111827]/40 border border-black/5 dark:border-white/5 hover:border-[#D4AF37]/50 rounded-[2rem] p-8 hover:-translate-y-2 transition-all duration-500 shadow-sm hover:shadow-xl">
            <h2 class="text-2xl font-['Playfair_Display'] font-bold text-[#1C1917] dark:text-white mb-4 group-hover:text-[#D4AF37] transition-colors">
              {kategori.kategori}
            </h2>
            <p class="text-[#57534E] dark:text-[#94A3B8] text-sm line-clamp-3 leading-relaxed transition-colors duration-500 font-light">
              {kategori.kategori_giris_yazisi}
            </p>
          </a>
        ))}
      </div>

    </div>
  </main>
</Layout>