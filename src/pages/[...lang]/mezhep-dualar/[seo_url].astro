---
import Layout from '../../../layouts/Layout.astro';
import { veriGetir } from '../../../utils/veriMotoru';
import { useTranslations } from '../../../i18n/ui';

// 🚀 SSR MİMARİSİ
const { lang = 'tr', seo_url } = Astro.params;
const t = useTranslations(lang);
const langPrefix = lang === 'tr' ? '' : `/${lang}`;

const mezhepDualari = veriGetir('mezhep_dualar_proje_hazir', lang) || [];
const dua = mezhepDualari.find(d => d.seo_url === seo_url);

if (!dua) {
  return Astro.redirect(`${langPrefix}/`);
}

const mezhepler = Object.keys(dua.mezhepler || {});

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": dua.dua_adi,
  "description": dua.ortak_tarihce,
  "inLanguage": lang
};

// 🌍 SAYFA İÇİ OTOMATİK ÇEVİRİ SÖZLÜĞÜ
const uiKarsilastirmaliFikih = {
  tr: 'Karşılaştırmalı Fıkıh',
  en: 'Comparative Fiqh',
  ar: 'الفقه المقارن',
  ru: 'Сравнительный фикх',
  fr: 'Fiqh Comparé',
  id: 'Fikih Komparatif',
  ur: 'تقابلی فقہ'
}[lang] || 'Karşılaştırmalı Fıkıh';

const uiOkunusu = {
  tr: 'Okunuşu',
  en: 'Pronunciation',
  ar: 'النطق',
  ru: 'Произношение',
  fr: 'Prononciation',
  id: 'Pelafalan',
  ur: 'تلفظ'
}[lang] || 'Okunuşu';

const uiMeali = {
  tr: 'Meali',
  en: 'Translation',
  ar: 'الترجمة',
  ru: 'Перевод',
  fr: 'Traduction',
  id: 'Terjemahan',
  ur: 'ترجمہ'
}[lang] || 'Meali';

const uiFikhiDayanak = {
  tr: 'Fıkhî Dayanak',
  en: 'Jurisprudential Basis',
  ar: 'الدليل الفقهي',
  ru: 'Юридическое обоснование (Фикх)',
  fr: 'Base Jurisprudentielle',
  id: 'Dasar Fikih',
  ur: 'فقہی دلیل'
}[lang] || 'Fıkhî Dayanak';
---

<Layout title={`${dua.dua_adi} | Islamic Compass`} description={dua.ortak_tarihce} schema={schema}>
  <main class="py-16 md:py-24 px-5 min-h-screen bg-[#FDFBF7] dark:bg-[#0B1120] transition-colors duration-500">
    <article class="max-w-4xl mx-auto">
      
      <header class="text-center mb-12 relative">
        <div class="inline-block px-4 py-1.5 rounded-full bg-[#D4AF37]/10 border border-[#D4AF37]/20 text-[#D4AF37] text-[10px] md:text-xs font-bold tracking-[0.2em] uppercase mb-6">
          {uiKarsilastirmaliFikih}
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-['Playfair_Display'] font-semibold text-[#1C1917] dark:text-white mb-8 leading-tight transition-colors duration-500">
          {dua.dua_adi}
        </h1>

        <div class="bg-white dark:bg-[#111827] rounded-3xl p-8 md:p-10 shadow-xl shadow-black/5 dark:shadow-white/5 border border-black/5 dark:border-white/5 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-1 h-full bg-[#D4AF37]"></div>
          <p class="text-[#57534E] dark:text-[#94A3B8] text-lg md:text-xl leading-relaxed font-light text-left">
            {dua.ortak_tarihce}
          </p>
        </div>
      </header>

      <div class="mt-16 bg-white dark:bg-[#111827] rounded-[2.5rem] shadow-2xl border border-black/5 dark:border-white/5 overflow-hidden transition-colors duration-500">
        
        <div class="flex flex-wrap md:flex-nowrap items-center border-b border-black/5 dark:border-white/5 bg-[#FDFBF7] dark:bg-[#0f1523]">
          {mezhepler.map((mezhep, index) => (
            <button 
              class={`tab-btn flex-1 py-5 px-4 text-center text-sm md:text-base font-bold uppercase tracking-widest transition-all duration-300 relative ${index === 0 ? 'text-[#D4AF37]' : 'text-[#94A3B8] hover:text-[#1C1917] dark:hover:text-white'}`}
              data-target={`tab-${mezhep}`}
            >
              {mezhep}
              <span class={`tab-indicator absolute bottom-0 left-0 w-full h-1 bg-[#D4AF37] transition-transform duration-300 ${index === 0 ? 'scale-x-100' : 'scale-x-0'}`}></span>
            </button>
          ))}
        </div>

        <div class="p-8 md:p-12 relative min-h-[400px]">
          {mezhepler.map((mezhep, index) => {
            const mData = dua.mezhepler[mezhep];
            return (
              <div id={`tab-${mezhep}`} class={`tab-content transition-all duration-500 absolute inset-0 p-8 md:p-12 ${index === 0 ? 'opacity-100 z-10 translate-y-0 relative' : 'opacity-0 z-0 translate-y-4 pointer-events-none hidden'}`}>
                
                {mData.arapca && (
                  <div class="mb-10 text-center">
                    <p class="text-3xl md:text-4xl lg:text-5xl text-[#1C1917] dark:text-white font-['Amiri'] leading-loose" dir="rtl">
                      {mData.arapca}
                    </p>
                  </div>
                )}
                
                {mData.okunus && (
                  <div class="mb-8">
                    <h3 class="text-[#D4AF37] text-xs font-bold tracking-[0.2em] uppercase mb-4 flex items-center gap-2">
                      <span class="w-1.5 h-1.5 rounded-full bg-[#D4AF37]"></span> {uiOkunusu}
                    </h3>
                    <p class="text-[#44403C] dark:text-white/90 text-lg leading-relaxed font-light" dir="ltr">
                      {mData.okunus}
                    </p>
                  </div>
                )}
                
                {mData.meal && (
                  <div class="mb-8">
                    <h3 class="text-[#D4AF37] text-xs font-bold tracking-[0.2em] uppercase mb-4 flex items-center gap-2">
                      <span class="w-1.5 h-1.5 rounded-full bg-[#D4AF37]"></span> {uiMeali}
                    </h3>
                    <p class="text-[#44403C] dark:text-white/90 text-lg leading-relaxed font-light">
                      {mData.meal}
                    </p>
                  </div>
                )}

                {mData.aciklama && (
                  <div class="mt-10 p-6 rounded-2xl bg-[#F5F2E9] dark:bg-[#0f1523] border border-[#D4AF37]/20">
                    <h3 class="text-[#D4AF37] text-[10px] font-bold tracking-[0.2em] uppercase mb-3">{uiFikhiDayanak}</h3>
                    <p class="text-[#57534E] dark:text-[#94A3B8] text-sm md:text-base font-light leading-relaxed">
                      {mData.aciklama}
                    </p>
                  </div>
                )}

              </div>
            );
          })}
        </div>
      </div>

    </article>
  </main>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const btns = document.querySelectorAll('.tab-btn');
      const contents = document.querySelectorAll('.tab-content');

      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          btns.forEach(b => {
            b.classList.remove('text-[#D4AF37]');
            b.classList.add('text-[#94A3B8]');
            b.querySelector('.tab-indicator').classList.remove('scale-x-100');
            b.querySelector('.tab-indicator').classList.add('scale-x-0');
          });
          
          contents.forEach(c => {
            c.classList.remove('opacity-100', 'z-10', 'translate-y-0', 'relative');
            c.classList.add('opacity-0', 'z-0', 'translate-y-4', 'pointer-events-none', 'hidden');
          });

          btn.classList.add('text-[#D4AF37]');
          btn.classList.remove('text-[#94A3B8]');
          btn.querySelector('.tab-indicator').classList.add('scale-x-100');
          btn.querySelector('.tab-indicator').classList.remove('scale-x-0');

          const targetId = btn.getAttribute('data-target');
          const targetContent = document.getElementById(targetId);
          
          if(targetContent) {
            targetContent.classList.remove('hidden');
            setTimeout(() => {
              targetContent.classList.remove('opacity-0', 'z-0', 'translate-y-4', 'pointer-events-none');
              targetContent.classList.add('opacity-100', 'z-10', 'translate-y-0', 'relative');
            }, 10);
          }
        });
      });
    });
  </script>
</Layout>