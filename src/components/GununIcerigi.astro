---
import { veriGetir } from '../utils/veriMotoru';
import { getLangFromUrl } from '../i18n/ui';

// Dili URL'den veya Component'ten al
const lang = Astro.props.lang || getLangFromUrl(Astro.url);
const langPrefix = lang === 'tr' ? '' : `/${lang}`;

// 7 DİLİN TAMAMINA UYUMLU KUSURSUZ SÖZLÜK
const ui = {
  tr: { badge: 'Gönül Pusulası Seçkisi', title: 'Günün İlhamı', wait: 'Yükleniyor...', sure: 'Günün Suresi', dua: 'Günün Duası', kissa: 'Günün Kıssası', kissaAlt: 'Kıssadan Hisse', esma: 'Günün Esması', hadis: 'Günün Hadisi', read: 'Külliyatı Oku' },
  en: { badge: "Islam's Compass Selection", title: 'Daily Inspiration', wait: 'Loading...', sure: 'Surah of the Day', dua: 'Dua of the Day', kissa: 'Parable of the Day', kissaAlt: 'Wisdom', esma: 'Name of the Day', hadis: 'Hadith of the Day', read: 'Read More' },
  ar: { badge: 'مختارات بوصلة الإسلام', title: 'إلهام اليوم', wait: 'جارٍ التحميل...', sure: 'سورة اليوم', dua: 'دعاء اليوم', kissa: 'قصة اليوم', kissaAlt: 'حكمة', esma: 'اسم اليوم', hadis: 'حديث اليوم', read: 'اقرأ المزيد' },
  id: { badge: 'Pilihan Kompas Islam', title: 'Inspirasi Harian', wait: 'Memuat...', sure: 'Surah Hari Ini', dua: 'Doa Hari Ini', kissa: 'Kisah Hari Ini', kissaAlt: 'Hikmah', esma: 'Asmaul Husna Hari Ini', hadis: 'Hadis Hari Ini', read: 'Baca Selengkapnya' },
  ur: { badge: 'اسلام کے قطب نما کا انتخاب', title: 'روزمرہ کی الہام', wait: 'لوڈ ہو رہا ہے...', sure: 'آج کی سورہ', dua: 'آج کی دعا', kissa: 'آج کا قصہ', kissaAlt: 'حکمت', esma: 'آج کا نام', hadis: 'آج کی حدیث', read: 'مزید پڑھیں' },
  fr: { badge: 'Sélection de la Boussole', title: 'Inspiration Quotidienne', wait: 'Chargement...', sure: 'Sourate du Jour', dua: 'Invocation du Jour', kissa: 'Histoire du Jour', kissaAlt: 'Sagesse', esma: 'Nom du Jour', hadis: 'Hadith du Jour', read: 'Lire la suite' },
  ru: { badge: 'Выбор Компаса Ислама', title: 'Вдохновение Дня', wait: 'Загрузка...', sure: 'Сура дня', dua: 'Дуа дня', kissa: 'История дня', kissaAlt: 'Мудрость', esma: 'Имя дня', hadis: 'Хадис дня', read: 'Читать далее' }
}[lang] || { badge: 'Gönül Pusulası Seçkisi', title: 'Günün İlhamı', wait: 'Yükleniyor...', sure: 'Günün Suresi', dua: 'Günün Duası', kissa: 'Günün Kıssası', kissaAlt: 'Kıssadan Hisse', esma: 'Günün Esması', hadis: 'Günün Hadisi', read: 'Külliyatı Oku' };

const isRtl = lang === 'ar' || lang === 'ur';

// Verileri Çok Dilli Motorumuzdan Çekiyoruz
const kuranData = veriGetir('kuran_proje_hazir', lang);
const dualarData = veriGetir('dualar_proje_hazir', lang);
const kissalarData = veriGetir('kissalar_proje_hazir', lang);
const esmaData = veriGetir('esmaul_husna_proje_hazir', lang);
const hadisData = veriGetir('hadisler_proje_hazir', lang);

// Tarayıcıya Gönderilecek Hafifletilmiş Veriler
const liteKuran = kuranData.map(s => ({ title: s.sure_adi || s.baslik || s.isim, no: s.sure_no, url: `${langPrefix}/kuran/${s.seo_url}`, desc: s.sayfa_giris_yazisi || "İlahi rehberden günün ayetleri..." }));
const liteDualar = dualarData.map(d => ({ title: d.baslik, cat: d.kategori, url: `${langPrefix}/dualar/${d.seo_url}`, desc: d.sayfa_giris_yazisi || d.turkce_anlam }));
const liteKissalar = kissalarData.map(k => ({ title: k.baslik, url: `${langPrefix}/kissalar/${k.seo_url}`, desc: k.alinacak_ders || k.sayfa_giris_yazisi }));
const liteEsma = esmaData.map(e => ({ title: e.isim, ar: e.arapca_yazilis, url: `${langPrefix}/esmaul-husna/${e.seo_url}`, desc: e.kisa_anlam }));
const liteHadis = hadisData.map(h => ({ title: h.kategori, url: `${langPrefix}/hadisler/${h.seo_url}`, desc: h.hadisler[0]?.turkce_anlam || "" }));
---
<div class={`w-full bg-[#1C1917] dark:bg-[#080C14] rounded-[3rem] p-8 md:p-16 text-white my-24 relative overflow-hidden shadow-2xl transition-colors duration-500 ${isRtl ? 'text-right' : 'text-left'}`} dir={isRtl ? 'rtl' : 'ltr'}>
  
  <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/arabesque.png')] pointer-events-none"></div>
  
  <div class="text-center mb-16 relative z-10">
    <span class="text-[#D4AF37] text-sm md:text-base font-bold tracking-[0.3em] uppercase mb-4 block">{ui.badge}</span>
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-['Playfair_Display'] font-semibold text-white mb-6">{ui.title}</h2>
    <div class="w-24 h-[1px] bg-[#D4AF37] mx-auto opacity-50"></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 relative z-10 mb-8 opacity-0 transition-opacity duration-1000" id="gunun-icerigi-row1">
    
    <a href="#" id="gi-sure-url" class="group flex flex-col justify-between bg-white/5 border border-white/10 p-8 md:p-10 rounded-[2rem] hover:bg-white/10 hover:border-[#D4AF37]/50 transition-all duration-500 backdrop-blur-sm">
      <div>
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 rounded-full bg-[#D4AF37]/20 flex items-center justify-center text-[#D4AF37]">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
          </div>
          <div>
            <h3 class="text-[#D4AF37] text-xs font-bold tracking-[0.2em] uppercase">{ui.sure}</h3>
            <span id="gi-sure-no" class="text-white/60 text-xs">{ui.wait}</span>
          </div>
        </div>
        <p id="gi-sure-desc" class="text-white/90 text-xl font-['Playfair_Display'] leading-relaxed mb-8 line-clamp-4 italic">{ui.wait}</p>
      </div>
      <div class="flex items-center justify-between border-t border-white/10 pt-6 mt-auto">
        <span id="gi-sure-title" class="text-white font-semibold font-['Playfair_Display'] text-lg">{ui.wait}</span>
        <svg class={`w-5 h-5 text-[#D4AF37] transform group-hover:${isRtl ? '-translate-x-2' : 'translate-x-2'} transition-transform duration-300 ${isRtl ? 'rotate-180' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </div>
    </a>

    <a href="#" id="gi-dua-url" class="group flex flex-col justify-between bg-white/5 border border-white/10 p-8 md:p-10 rounded-[2rem] hover:bg-white/10 hover:border-[#D4AF37]/50 transition-all duration-500 backdrop-blur-sm relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-[#D4AF37]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="relative z-10 flex flex-col h-full">
        <div>
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-full bg-[#D4AF37]/20 flex items-center justify-center text-[#D4AF37]">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
            </div>
            <div>
              <h3 class="text-[#D4AF37] text-xs font-bold tracking-[0.2em] uppercase">{ui.dua}</h3>
              <span id="gi-dua-cat" class="text-white/60 text-xs">{ui.wait}</span>
            </div>
          </div>
          <p id="gi-dua-desc" class="text-white/90 text-xl font-['Playfair_Display'] leading-relaxed mb-8 line-clamp-4 italic">{ui.wait}</p>
        </div>
        <div class="flex items-center justify-between border-t border-white/10 pt-6 mt-auto relative z-10">
          <span id="gi-dua-title" class="text-white font-semibold font-['Playfair_Display'] text-lg line-clamp-1 pr-4">{ui.wait}</span>
          <svg class={`w-5 h-5 text-[#D4AF37] transform group-hover:${isRtl ? '-translate-x-2' : 'translate-x-2'} transition-transform duration-300 flex-shrink-0 ${isRtl ? 'rotate-180' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </div>
      </div>
    </a>

    <a href="#" id="gi-kissa-url" class="group flex flex-col justify-between bg-white/5 border border-white/10 p-8 md:p-10 rounded-[2rem] hover:bg-white/10 hover:border-[#D4AF37]/50 transition-all duration-500 backdrop-blur-sm">
      <div>
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 rounded-full bg-[#D4AF37]/20 flex items-center justify-center text-[#D4AF37]">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"></path></svg>
          </div>
          <div>
            <h3 class="text-[#D4AF37] text-xs font-bold tracking-[0.2em] uppercase">{ui.kissa}</h3>
            <span class="text-white/60 text-xs">{ui.kissaAlt}</span>
          </div>
        </div>
        <p id="gi-kissa-desc" class="text-white/90 text-xl font-['Playfair_Display'] leading-relaxed mb-8 line-clamp-4 italic">{ui.wait}</p>
      </div>
      <div class="flex items-center justify-between border-t border-white/10 pt-6 mt-auto">
        <span id="gi-kissa-title" class="text-white font-semibold font-['Playfair_Display'] text-lg line-clamp-1 pr-4">{ui.wait}</span>
        <svg class={`w-5 h-5 text-[#D4AF37] transform group-hover:${isRtl ? '-translate-x-2' : 'translate-x-2'} transition-transform duration-300 flex-shrink-0 ${isRtl ? 'rotate-180' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </div>
    </a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 relative z-10 max-w-4xl mx-auto opacity-0 transition-opacity duration-1000 delay-150" id="gunun-icerigi-row2">
    
    <a href="#" id="gi-esma-url" class="group flex flex-col justify-between bg-gradient-to-br from-[#D4AF37]/5 to-transparent border border-[#D4AF37]/20 p-8 md:p-10 rounded-[2rem] hover:bg-[#D4AF37]/10 hover:border-[#D4AF37]/50 transition-all duration-500 backdrop-blur-sm relative overflow-hidden">
      <div id="gi-esma-ar" class="absolute -right-4 -top-4 text-8xl text-[#D4AF37] opacity-10 group-hover:opacity-20 font-['Amiri'] transition-opacity duration-500 pointer-events-none select-none"></div>
      <div class="relative z-10 flex flex-col h-full">
        <div>
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-full bg-[#D4AF37]/20 flex items-center justify-center text-[#D4AF37]">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
            </div>
            <div>
              <h3 class="text-[#D4AF37] text-xs font-bold tracking-[0.2em] uppercase">{ui.esma}</h3>
              <span class="text-white/60 text-xs">Esmaül Hüsna</span>
            </div>
          </div>
          <p id="gi-esma-desc" class="text-white/90 text-xl font-['Playfair_Display'] leading-relaxed mb-8 line-clamp-3 italic">{ui.wait}</p>
        </div>
        <div class="flex items-center justify-between border-t border-[#D4AF37]/20 pt-6 mt-auto relative z-10">
          <span id="gi-esma-title" class="text-[#D4AF37] font-bold font-['Playfair_Display'] text-2xl line-clamp-1 pr-4">{ui.wait}</span>
          <svg class={`w-5 h-5 text-[#D4AF37] transform group-hover:${isRtl ? '-translate-x-2' : 'translate-x-2'} transition-transform duration-300 flex-shrink-0 ${isRtl ? 'rotate-180' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </div>
      </div>
    </a>

    <a href="#" id="gi-hadis-url" class="group flex flex-col justify-between bg-white/5 border border-white/10 p-8 md:p-10 rounded-[2rem] hover:bg-white/10 hover:border-[#D4AF37]/50 transition-all duration-500 backdrop-blur-sm">
      <div class="flex flex-col h-full">
        <div>
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-full bg-[#D4AF37]/20 flex items-center justify-center text-[#D4AF37]">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
            </div>
            <div>
              <h3 class="text-[#D4AF37] text-xs font-bold tracking-[0.2em] uppercase">{ui.hadis}</h3>
              <span id="gi-hadis-title" class="text-white/60 text-xs">{ui.wait}</span>
            </div>
          </div>
          <p id="gi-hadis-desc" class="text-white/90 text-xl font-['Playfair_Display'] leading-relaxed mb-8 line-clamp-4 font-medium">{ui.wait}</p>
        </div>
        <div class="flex items-center justify-between border-t border-white/10 pt-6 mt-auto">
          <span class="text-white font-semibold font-['Playfair_Display'] text-sm tracking-widest uppercase">{ui.read}</span>
          <svg class={`w-5 h-5 text-[#D4AF37] transform group-hover:${isRtl ? '-translate-x-2' : 'translate-x-2'} transition-transform duration-300 flex-shrink-0 ${isRtl ? 'rotate-180' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </div>
      </div>
    </a>

  </div>
</div>

<script is:inline define:vars={{ liteKuran, liteDualar, liteKissalar, liteEsma, liteHadis, isRtl }}>
  document.addEventListener('DOMContentLoaded', () => {
    const today = new Date();
    const dateString = `${today.getFullYear()}-${today.getMonth()}-${today.getDate()}`;
    
    let hash = 0;
    for (let i = 0; i < dateString.length; i++) hash = dateString.charCodeAt(i) + ((hash << 5) - hash);
    const absHash = Math.abs(hash);

    const gKuran = liteKuran[absHash % liteKuran.length];
    const gDua = liteDualar[absHash % liteDualar.length];
    const gKissa = liteKissalar[absHash % liteKissalar.length];
    const gEsma = liteEsma[absHash % liteEsma.length];
    const gHadis = liteHadis[absHash % liteHadis.length];

    if(gKuran) {
      document.getElementById('gi-sure-url').href = gKuran.url;
      document.getElementById('gi-sure-no').textContent = `${gKuran.no}`;
      document.getElementById('gi-sure-desc').textContent = `"${gKuran.desc}"`;
      document.getElementById('gi-sure-title').textContent = gKuran.title;
    }

    if(gDua) {
      document.getElementById('gi-dua-url').href = gDua.url;
      document.getElementById('gi-dua-cat').textContent = gDua.cat;
      document.getElementById('gi-dua-desc').textContent = `"${gDua.desc}"`;
      document.getElementById('gi-dua-title').textContent = gDua.title;
    }

    if(gKissa) {
      document.getElementById('gi-kissa-url').href = gKissa.url;
      document.getElementById('gi-kissa-desc').textContent = `"${gKissa.desc}"`;
      document.getElementById('gi-kissa-title').textContent = gKissa.title;
    }

    if(gEsma) {
      document.getElementById('gi-esma-url').href = gEsma.url;
      document.getElementById('gi-esma-ar').textContent = gEsma.ar;
      document.getElementById('gi-esma-desc').textContent = `"${gEsma.desc}"`;
      document.getElementById('gi-esma-title').textContent = gEsma.title;
    }

    if(gHadis) {
      document.getElementById('gi-hadis-url').href = gHadis.url;
      document.getElementById('gi-hadis-title').textContent = gHadis.title;
      document.getElementById('gi-hadis-desc').textContent = `"${gHadis.desc}"`;
    }

    document.getElementById('gunun-icerigi-row1').classList.remove('opacity-0');
    document.getElementById('gunun-icerigi-row2').classList.remove('opacity-0');
  });
</script>