---
import { getLangFromUrl } from '../i18n/ui';
const lang = Astro.props.lang || getLangFromUrl(Astro.url);
const isRtl = lang === 'ar' || lang === 'ur';

const ui = {
  tr: { loading: 'Yükleniyor...' },
  en: { loading: 'Loading...' },
  ar: { loading: 'جارٍ التحميل...' }
}[lang] || { loading: 'Yükleniyor...' };
---
<div id="vakitler-widget" class={`hidden md:flex items-center gap-4 text-sm bg-black/5 dark:bg-white/5 py-1.5 px-4 rounded-full border border-black/10 dark:border-white/10 ${isRtl ? 'flex-row-reverse' : ''} transition-colors duration-500`}>
  
  <div class={`flex items-center gap-2 text-[#D4AF37] ${isRtl ? 'flex-row-reverse' : ''}`}>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
    <span id="hicri-tarih" class="font-medium tracking-wide" dir="ltr">{ui.loading}</span>
  </div>

  <div class="w-px h-4 bg-black/20 dark:bg-white/20"></div>

  <div class={`flex items-center gap-2 ${isRtl ? 'flex-row-reverse' : ''}`}>
    <span class={`text-[#57534E] dark:text-[#94A3B8] hidden lg:flex items-center gap-1 ${isRtl ? 'flex-row-reverse' : ''}`} title="Location">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
      <span id="vakit-sehir" class="truncate max-w-[80px]">Istanbul</span>
    </span>
    <div class="w-1 h-1 rounded-full bg-black/20 dark:bg-white/20 mx-1 hidden lg:block"></div>
    <span id="siradaki-vakit-isim" class="font-bold text-[#1C1917] dark:text-white capitalize">-</span>
    <span id="siradaki-vakit-saat" class="font-medium text-[#D4AF37] font-mono tracking-wider bg-[#D4AF37]/10 px-2 py-0.5 rounded ml-1" dir="ltr">-</span>
  </div>
</div>

<script is:inline define:vars={{ lang }}>
  document.addEventListener('DOMContentLoaded', async () => {
    const hicriEl = document.getElementById('hicri-tarih');
    const vakitIsimEl = document.getElementById('siradaki-vakit-isim');
    const vakitSaatEl = document.getElementById('siradaki-vakit-saat');
    const widgetEl = document.getElementById('vakitler-widget');
    const sehirEl = document.getElementById('vakit-sehir');

    if(!hicriEl || !vakitIsimEl) return;

    try {
      let city = 'Istanbul';
      let country = 'Turkey';
      let displayName = 'İstanbul';

      try {
        const ipRes = await fetch('https://ipapi.co/json/');
        if (ipRes.ok) {
           const ipData = await ipRes.json();
           if (ipData.city) { city = ipData.city; displayName = ipData.city; }
           if (ipData.country_name) country = ipData.country_name;
        }
      } catch (e) { console.log("Varsayılan konum kullanılıyor."); }

      if (sehirEl) sehirEl.textContent = displayName;

      const response = await fetch(`https://api.aladhan.com/v1/timingsByCity?city=${encodeURIComponent(city)}&country=${encodeURIComponent(country)}&method=13`);
      if (!response.ok) throw new Error('API Error');
      
      const data = await response.json();
      
      if(data.code === 200) {
        const timings = data.data.timings;
        const hijri = data.data.date.hijri;

        // DİLE GÖRE HİCRİ AY İSİMLERİ VE NAMAZ VAKİTLERİ (Çok Dilli Sözlük)
        const trAylar = { "Muharram": "Muharrem", "Safar": "Safer", "Rabi' al-awwal": "Rebiülevvel", "Rabi' al-thani": "Rebiülahir", "Jumada al-awwal": "Cemaziyelevvel", "Jumada al-thani": "Cemaziyelahir", "Rajab": "Recep", "Sha'ban": "Şaban", "Ramadan": "Ramazan", "Shawwal": "Şevval", "Dhu al-Qi'dah": "Zilkade", "Dhu al-Hijjah": "Zilhicce" };
        const arAylar = { "Muharram": "محرّم", "Safar": "صفر", "Rabi' al-awwal": "ربيع الأول", "Rabi' al-thani": "ربيع الآخر", "Jumada al-awwal": "جمادى الأولى", "Jumada al-thani": "جمادى الآخرة", "Rajab": "رجب", "Sha'ban": "شعبان", "Ramadan": "رمضان", "Shawwal": "شوّال", "Dhu al-Qi'dah": "ذو القعدة", "Dhu al-Hijjah": "ذو الحجة" };
        
        let ayAdi = hijri.month.en;
        if (lang === 'tr') ayAdi = trAylar[hijri.month.en] || ayAdi;
        if (lang === 'ar') ayAdi = arAylar[hijri.month.en] || ayAdi;

        hicriEl.textContent = lang === 'ar' ? `${hijri.year} ${ayAdi} ${hijri.day}` : `${hijri.day} ${ayAdi} ${hijri.year}`;

        const now = new Date();
        const currentTimeInMinutes = now.getHours() * 60 + now.getMinutes();

        const parseTime = (timeStr) => { const [h, m] = timeStr.split(':').map(Number); return h * 60 + m; };

        // Çok Dilli Vakit İsimleri
        const names = {
          tr: ['İmsak', 'Güneş', 'Öğle', 'İkindi', 'Akşam', 'Yatsı'],
          en: ['Fajr', 'Sunrise', 'Dhuhr', 'Asr', 'Maghrib', 'Isha'],
          ar: ['الفجر', 'الشروق', 'الظهر', 'العصر', 'المغرب', 'العشاء']
        }[lang] || ['Fajr', 'Sunrise', 'Dhuhr', 'Asr', 'Maghrib', 'Isha'];

        const vakitler = [
          {isim: names[0], sure: parseTime(timings.Imsak), saat: timings.Imsak},
          {isim: names[1], sure: parseTime(timings.Sunrise), saat: timings.Sunrise},
          {isim: names[2], sure: parseTime(timings.Dhuhr), saat: timings.Dhuhr},
          {isim: names[3], sure: parseTime(timings.Asr), saat: timings.Asr},
          {isim: names[4], sure: parseTime(timings.Maghrib), saat: timings.Maghrib},
          {isim: names[5], sure: parseTime(timings.Isha), saat: timings.Isha}
        ];

        let siradakiVakit = vakitler[0]; 
        for (let i = 0; i < vakitler.length; i++) {
          if (currentTimeInMinutes < vakitler[i].sure) { siradakiVakit = vakitler[i]; break; }
        }

        vakitIsimEl.textContent = siradakiVakit.isim;
        vakitSaatEl.textContent = siradakiVakit.saat;
        
        widgetEl.classList.remove('hidden');
        widgetEl.style.display = 'flex';
        
      }
    } catch (error) { console.error("Widget Load Error:", error); }
  });
</script>